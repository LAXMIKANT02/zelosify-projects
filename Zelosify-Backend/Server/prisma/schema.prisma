generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(uuid())
  username        String?      @unique 
  email           String
  firstName       String?
  lastName        String?
  phoneNumber     String?
  department      String?
  role            Role
  tenantId        String?
  externalId      String?      @unique 
  totpSecret      String?
  profileComplete Boolean      @default(false)
  provider        AuthProvider @default(KEYCLOAK)
  creator         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Add the new optional token fields:
  accessToken     String?
  refreshToken    String?

  // Relation to tenant
  tenant          Tenants?     @relation(fields: [tenantId], references: [tenantId])

  openings        Opening[]
  uploadedProfiles HiringProfile[] @relation("Uploader")

  @@unique([email, provider])
  @@index([tenantId])
}

model Tenants {
  tenantId            String    @id @default(uuid())
  companyName         String    @default("DemoTenant")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users               User[]
  openings            Opening[]
  hiringProfiles      HiringProfile[]
}

enum AuthProvider {
  KEYCLOAK
  GOOGLE
  MICROSOFT
}

enum Role {
  ADMIN
  BUSINESS_APPROVER
  BUSINESS_USER
  FINANCE_MANAGER
  HIRING_MANAGER
  IT_VENDOR
  PROCUREMENT_MANAGER
  RESOURCE_MANAGER
  VENDOR_MANAGER
}

// [MODIFY - REQUIRED & JUSTIFIED]
// Reason: Required by assignment, not present in schema

model Opening {
  id              String   @id @default(uuid())
  title           String
  description     String
  location        String
  experienceMin   Int      @default(0)
  experienceMax   Int      @default(10)
  
  tenantId        String
  tenant          Tenants  @relation(fields: [tenantId], references: [tenantId])
  
  hiringManagerId String
  hiringManager   User     @relation(fields: [hiringManagerId], references: [id])
  
  profiles        HiringProfile[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([tenantId])
}

model HiringProfile {
  id                      String   @id @default(uuid())
  s3Key                   String
  status                  String   @default("PENDING") // PENDING, SHORTLISTED, REJECTED
  
  recommended             Boolean?
  recommendationScore     Float?
  recommendationConfidence Float?
  recommendationReason    String?
  recommendationLatencyMs Int?
  
  openingId               String
  opening                 Opening  @relation(fields: [openingId], references: [id])
  
  tenantId                String?
  tenant                  Tenants? @relation(fields: [tenantId], references: [tenantId])
  
  uploadedBy              String
  uploader                User     @relation("Uploader", fields: [uploadedBy], references: [id])
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@index([openingId])
  @@index([tenantId])
}